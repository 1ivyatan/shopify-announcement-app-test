<script>
    // Set widget from metafield (or null if doesn't exist)
    {% if app.metafields.libautech_leons.code.value %}
    window.LBTANN_RAW_CODE = {{ app.metafields.libautech_leons.code.value | json }};
    window.LBTANN_CODE = window.LBTANN_RAW_CODE.code;
    window.LBTANN_CODE_VERSION = window.LBTANN_RAW_CODE.version;
    {% else %}
    window.LBTANN_CODE = null;
    window.LBTANN_CODE_VERSION = null;
    {% endif %}

    // Async function to load widget - returns instantly if metafield exists, fetches if not
    window.LBTANN_loadCode = async function () {
        if (window.LBTANN_CODE) {
            console.debug("LBTANN: Using Libau widget from metafield", {
                version: window.LBTANN_CODE_VERSION
            });
            // Metafield exists, return immediately
            return {
                code: window.LBTANN_CODE,
                version: window.LBTANN_CODE_VERSION,
                source: 'metafield'
            };
        }

        console.debug("LBTANN: Libau widget not found in metafield, fetching from proxy...");

        // No metafield, fetch from proxy
        try {
            const response = await fetch('/apps/libautech-upsell/widget');
            if (!response.ok) throw new Error('Failed to fetch widget');

            const code = await response.json();

            window.LBTANN_CODE = code.code;

            return {
                code: code.code,
                version: 'proxy', // Set to sentinel value 'proxy' to differentiate source
                source: 'proxy'
            };
        } catch (error) {
            console.error('Failed to load Libau widget:', error);
            throw error;
        }
    };
</script>